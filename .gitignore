# Hidden folders (.*) — but keep CI config tracked
.*/
!.github/

# Rust build artifacts
/target
debug
target

# Lockfile is fine to keep for a binary/app; uncomment to ignore if desired
# Cargo.lock

# Android Gradle build outputs
android/.gradle/
android/build/
android/app/build/
android/app/src/main/jniLibs/

# Screenshot / debug capture artifacts
*.png

# Runtime logs
app_err.log
app_out.log

# Debug frame captures
frame_*.ppm

# Prebuilt slang toolchain (downloaded by CI via curl; glibc binary, not used
# on Termux). Never commit the 60+ MB release tree — it is fetched at build time.
tools/slang/

# Precomputed IBL convolution cache (auto-generated; see docs/lessons-learned.md §32)
assets/ibr/

# Scene model assets (large; referenced via assets/scenes.toml virtual mapping,
# not committed). The manifest file assets/scenes.toml itself stays tracked.
assets/scenes/*
!assets/scenes/*.toml
